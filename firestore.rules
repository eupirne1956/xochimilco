rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net: any unmapped path or operation is rejected
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // Phase 3: Primitive Helpers
    // ==========================================
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    // Auth token contains authentic state
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    // Checking root super admin based on Google Sign-In verified email claim, and validating other whitelist admin roles relational lookup
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "eupirne@gmail.com" ||
        (exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)).data.role == "admin")
      );
    }

    // ==========================================
    // Schema Check and Validation Blueprints
    // ==========================================
    function isValidUserProfile(data) {
      return data.keys().hasAll(['id', 'email', 'firstName', 'lastName', 'username', 'avatarColor', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100 // Last name can be blank string
        && data.username is string && data.username.size() > 0 && data.username.size() <= 100
        && data.avatarColor is string && data.avatarColor.size() > 0 && data.avatarColor.size() <= 20
        && data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() <= 100;
    }

    function isValidAuthorizedUser(data) {
      return data.keys().hasAll(['email', 'role', 'access_granted_at', 'access_expires_at'])
        && data.keys().size() >= 4 && data.keys().size() <= 8
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.role is string && (data.role == "admin" || data.role == "user")
        && data.access_granted_at is timestamp
        && data.access_expires_at is timestamp
        && (!data.keys().hasAll(['name']) || (data.name is string && data.name.size() <= 200))
        && (!data.keys().hasAll(['password']) || (data.password is string && data.password.size() <= 256))
        && (!data.keys().hasAll(['is_expiry_warning_sent']) || (data.is_expiry_warning_sent is bool))
        && (!data.keys().hasAll(['warning_sent_2_days']) || (data.warning_sent_2_days is bool));
    }

    // ==========================================
    // Collections
    // ==========================================

    // Users Collection Hardening
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.id == request.auth.uid;
      
      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidUserProfile(incoming())
                    && incoming().id == userId
                    && (incoming().email == request.auth.token.email || (request.auth.token.email_verified == false && incoming().email == request.auth.token.email)); // verify email bound to token
                    
      allow update: if isOwner(userId)
                    && isValidUserProfile(incoming())
                    && incoming().id == existing().id
                    && incoming().email == existing().email
                    && incoming().createdAt == existing().createdAt
                    && (
                      // Only allow updating subset of editable fields
                      incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'username', 'avatarColor'])
                    );
                    
      allow delete: if isOwner(userId);
    }

    // Authorized Whitelist Collection Hardening
    match /authorized_users/{userEmail} {
      allow get: if true;
      allow list: if isAdmin();
      
      allow create: if (incoming().role == "user" || isAdmin())
                    && isValidAuthorizedUser(incoming())
                    && incoming().email == userEmail;
                    
      allow update: if (incoming().role == "user" || isAdmin())
                    && isValidAuthorizedUser(incoming())
                    && incoming().email == userEmail;
                    
      allow delete: if isAdmin();
    }
  }
}
